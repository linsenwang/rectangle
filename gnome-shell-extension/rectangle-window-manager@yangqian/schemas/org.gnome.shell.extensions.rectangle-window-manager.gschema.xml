<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <schema id="org.gnome.shell.extensions.rectangle-window-manager" path="/org/gnome/shell/extensions/rectangle-window-manager/">

    <!-- 基础窗口管理 -->
    <key name="left-half" type="as">
      <default><![CDATA[["<Control><Alt>Left"]]]></default>
      <summary>左半屏循环</summary>
    </key>

    <key name="right-half" type="as">
      <default><![CDATA[["<Control><Alt>Right"]]]></default>
      <summary>右半屏循环</summary>
    </key>

    <key name="top-half" type="as">
      <default><![CDATA[["<Control><Alt>Up"]]]></default>
      <summary>上半屏</summary>
    </key>

    <key name="maximize" type="as">
      <default><![CDATA[["<Control><Alt>Return"]]]></default>
      <summary>最大化（带边距）</summary>
    </key>

    <key name="restore-window" type="as">
      <default><![CDATA[["<Control><Alt>BackSpace"]]]></default>
      <summary>还原窗口</summary>
    </key>

    <key name="center-window" type="as">
      <default><![CDATA[["<Control><Alt>c"]]]></default>
      <summary>窗口居中</summary>
    </key>

    <key name="almost-maximize" type="as">
      <default><![CDATA[["<Control><Alt>l"]]]></default>
      <summary>几乎最大化</summary>
    </key>

    <key name="snap-left" type="as">
      <default><![CDATA[["<Control><Alt>semicolon"]]]></default>
      <summary>靠最左</summary>
    </key>

    <key name="snap-right" type="as">
      <default><![CDATA[["<Control><Alt>apostrophe"]]]></default>
      <summary>靠最右</summary>
    </key>

    <!-- 四角 -->
    <key name="top-left" type="as">
      <default><![CDATA[["<Control><Alt>u"]]]></default>
      <summary>左上 1/4</summary>
    </key>

    <key name="top-right" type="as">
      <default><![CDATA[["<Control><Alt>i"]]]></default>
      <summary>右上 1/4</summary>
    </key>

    <key name="bottom-left" type="as">
      <default><![CDATA[["<Control><Alt>0"]]]></default>
      <summary>左下 1/4</summary>
    </key>

    <key name="bottom-right" type="as">
      <default><![CDATA[["<Control><Alt>2"]]]></default>
      <summary>右下 1/4</summary>
    </key>

    <!-- 三分之一 -->
    <key name="left-third" type="as">
      <default><![CDATA[["<Control><Alt>comma"]]]></default>
      <summary>左 1/3 循环</summary>
    </key>

    <key name="right-third" type="as">
      <default><![CDATA[["<Control><Alt>period"]]]></default>
      <summary>右 1/3 循环</summary>
    </key>

    <!-- 调整大小 -->
    <key name="grow-width" type="as">
      <default><![CDATA[["<Control><Alt>equal"]]]></default>
      <summary>增大窗口宽度</summary>
    </key>

    <key name="shrink-width" type="as">
      <default><![CDATA[["<Control><Alt>minus"]]]></default>
      <summary>缩小窗口宽度</summary>
    </key>

    <!-- 显示器切换 -->
    <key name="move-screen-west" type="as">
      <default><![CDATA[["<Control><Alt><Shift>Left"]]]></default>
      <summary>移到左侧显示器</summary>
    </key>

    <key name="move-screen-east" type="as">
      <default><![CDATA[["<Control><Alt><Shift>Right"]]]></default>
      <summary>移到右侧显示器</summary>
    </key>

    <key name="maximize-height" type="as">
      <default><![CDATA[["<Control><Alt><Shift>Up"]]]></default>
      <summary>最大化高度</summary>
    </key>

    <!-- 窗口微调移动（原 Cmd+Option+方向键，Linux 上映射为 Super+Alt） -->
    <key name="move-left" type="as">
      <default><![CDATA[["<Super><Alt>Left"]]]></default>
      <summary>窗口左移</summary>
    </key>

    <key name="move-right" type="as">
      <default><![CDATA[["<Super><Alt>Right"]]]></default>
      <summary>窗口右移</summary>
    </key>

    <key name="move-up" type="as">
      <default><![CDATA[["<Super><Alt>Up"]]]></default>
      <summary>窗口上移</summary>
    </key>

    <key name="move-down" type="as">
      <default><![CDATA[["<Super><Alt>Down"]]]></default>
      <summary>窗口下移</summary>
    </key>

    <!-- 窗口交换 -->
    <key name="swap-windows" type="as">
      <default><![CDATA[["<Control><Alt>x"]]]></default>
      <summary>与上一个焦点窗口交换位置</summary>
    </key>

  </schema>
</schemalist>
